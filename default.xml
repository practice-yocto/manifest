<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <remote
        name="github-yocto"
        fetch="https://github.com/yoctoproject" />
    <remote 
        name="practice-yocto"
        fetch="https://github.com/practice-yocto" />
    <default
        revision="main"
        remote="practice-yocto"
        sync-j="8" />
    
    <!-- yocto projects -->
    <project path="poky" name="poky" remote="github-yocto" revision="kirkstone" />
    <!-- end yocto projects -->

    <!-- practice projects -->
    <project path="scripts" name="scripts">
        <linkfile src="envsetup.sh" dest="envsetup.sh" />
    </project>
    <project path="documents" name="documents" revision="main" />
    <project path="layers/meta-practice" name="meta-practice" revision="main" />
    <project path="layers/meta-practice-bsp" name="meta-practice-bsp" revision="main" />
    <project path="layers/meta-helloworld" name="meta-helloworld" revision="main" />
    <project path="layers/meta-nano-editor" name="meta-nano-editor" revision="main" />

    <project path="externalsrc/kernel-source" name="linux" revision="v5.15/dev" />
    <!-- end practice projects -->
</manifest>
